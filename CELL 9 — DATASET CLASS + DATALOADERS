

class KidneyDataset(Dataset):
    LABEL_MAP = {"Normal": 0, "Cyst": 1, "Tumor": 2, "Stone": 3}

    def __init__(self, dataframe, vocab, max_len=80, augment=False):
        self.df      = dataframe.reset_index(drop=True)
        self.vocab   = vocab
        self.max_len = max_len

        base = [
            transforms.Resize((224, 224)),
            transforms.ToTensor(),
            transforms.Normalize(mean=[0.485, 0.456, 0.406],
                                 std =[0.229, 0.224, 0.225])
        ]
        aug = [
            transforms.RandomHorizontalFlip(p=0.5),
            transforms.RandomRotation(10),
            transforms.ColorJitter(brightness=0.15, contrast=0.15),
        ]
        self.transform = transforms.Compose((aug + base) if augment else base)

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):
        row     = self.df.iloc[idx]
        img_bgr = cv2.imread(row["image_path"])

        # ── Safety check: skip corrupted/unreadable images ──
        if img_bgr is None:
            # Return a blank black image instead of crashing
            img_bgr = np.zeros((224, 224, 3), dtype=np.uint8)

        img_gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)
        img_enh  = apply_gamma_correction(img_gray)
        img_rgb  = cv2.cvtColor(img_enh, cv2.COLOR_GRAY2RGB)
        img_t    = self.transform(Image.fromarray(img_rgb))

        rep_ids = self.vocab.encode(row["report"], self.max_len)
        rep_t   = torch.tensor(rep_ids, dtype=torch.long)
        label   = self.LABEL_MAP.get(row["label"], 0)
        return img_t, rep_t, label


