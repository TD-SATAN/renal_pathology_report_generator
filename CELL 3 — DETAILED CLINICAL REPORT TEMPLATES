def make_report(label):
    """
    Generates a complete, realistic clinical radiology report for a given
    renal condition label.

    Args:
        label : one of "Normal", "Cyst", "Tumor", "Stone"

    Returns:
        report_text : full multi-section report string
    """
    templates = REPORT_TEMPLATES.get(label, REPORT_TEMPLATES["Normal"])
    template  = random.choice(templates)

    today    = datetime.date.today()
    exam_day = today - datetime.timedelta(days=random.randint(0, 30))
    r_size   = round(random.uniform(9.2, 11.8), 1)
    l_size   = round(random.uniform(9.2, 11.8), 1)
    stone_size = random.randint(4, 14)

    # Stone passage probability text
    if stone_size < 4:
        pass_prob      = "High — likely to pass spontaneously"
        pass_prob_long = "Your stone is small and has a good chance of passing on its own."
    elif stone_size <= 6:
        pass_prob      = "Moderate — ~59% chance of spontaneous passage"
        pass_prob_long = f"Your stone ({stone_size}mm) has about a 50-60% chance of passing on its own."
    else:
        pass_prob      = "Low — intervention likely required"
        pass_prob_long = f"Your stone ({stone_size}mm) is unlikely to pass on its own and may need a procedure."

    fields = dict(
        date           = exam_day.strftime("%d %B %Y"),
        pid            = f"CT-{random.randint(10000, 99999)}",
        ref_doc        = f"{random.choice(LAST_NAMES)} ({random.choice(SPECIALTIES)})",
        rad_doc        = random.choice(RADIOLOGISTS),
        indication     = random.choice(INDICATIONS),
        r_size         = r_size,
        l_size         = l_size,
        location       = random.choice(LOCATIONS),
        # Cyst
        cyst_size      = round(random.uniform(1.2, 5.5), 1),
        # Tumor
        tumor_size     = round(random.uniform(2.5, 8.0), 1),
        # Stone
        stone_size     = stone_size,
        stone_num      = random.randint(1, 4),
        stone_hu       = random.randint(400, 1200),
        hyd_grade      = random.randint(1, 3),
        pelvis_size    = random.randint(12, 22),
        urt_size       = random.randint(6, 14),
        pass_prob      = pass_prob,
        pass_prob_long = pass_prob_long,
    )

    try:
        return template.format(**fields)
    except KeyError as e:
        print(f"Warning: missing field {e}")
        return template

print("✅ Clinical report templates loaded!")
print("   Test report preview (Stone):")
print(make_report("Stone")[:300] + "...\n")
