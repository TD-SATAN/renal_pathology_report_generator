

def apply_gamma_correction(image_array, threshold=0.3):
    """
    Adaptive gamma correction — the best enhancement method per the IEEE paper.
    - Too dark  (mean < 0.3) → gamma = 0.7  (brightens image)
    - Too bright (mean > 0.7) → gamma = 1.5  (darkens image)
    - Normal                 → gamma = 1.0  (no change)
    """
    img_norm       = image_array.astype(np.float32) / 255.0
    mean_brightness = np.mean(img_norm)

    if mean_brightness < threshold:
        gamma = 0.7
    elif mean_brightness > (1 - threshold):
        gamma = 1.5
    else:
        gamma = 1.0

    enhanced = np.power(img_norm, gamma)
    return (enhanced * 255).clip(0, 255).astype(np.uint8)


def compare_enhancements(image_path):
    """Side-by-side comparison of all 4 enhancement methods (Figure 4 from paper)."""
    original = cv2.imread(image_path, cv2.IMREAD_GRAYSCALE)
    he       = cv2.equalizeHist(original)
    clahe    = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8)).apply(original)
    eff      = cv2.convertScaleAbs(original, alpha=1.3, beta=20)
    gamma    = apply_gamma_correction(original)

    titles = ["Original", "HE", "CLAHE", "EFF", "Gamma ✓ (Best)"]
    images = [original, he, clahe, eff, gamma]
    fig, axes = plt.subplots(1, 5, figsize=(18, 4))
    fig.suptitle("Enhancement Comparison — CT Kidney Image (Figure 4)", fontsize=12)
    for ax, img, title in zip(axes, images, titles):
        ax.imshow(img, cmap="gray")
        ax.set_title(title, fontsize=10)
        ax.axis("off")
    plt.tight_layout()
    plt.savefig("enhancement_comparison.png", dpi=100)
    plt.show()
    print("✅ Enhancement comparison saved.")

compare_enhancements(df_all["image_path"].iloc[0])
